{
  "_provenance": "Hand-derived from Sprint 3 Spec Critic design (team-lead dispatch brief). Scenario inputs are plain integers, enum strings, and ISO-8601 timestamps. No producer-computed rates or percents are pinned — verdicts are enum-constrained (CLEAR/WATCH/BREACH), staleness is derived from frozen_at timestamps relative to a known reference date. All spec_bundle_ids are synthetic hashes for isolation.",
  "_design_refs": [
    "Sprint-3 Spec Critic dispatch brief — indicator definitions",
    "council synthesis §2.5 (Phase-1 THEORY facets: gamma, utility_family, wealth_argument)",
    "autotuner.NN1_HONEST_DISCIPLINES (canonical honest discipline set)",
    "database.advisor_ro_query (wall-integrity contract)"
  ],

  "phase1_required_facets": ["gamma", "utility_family", "wealth_argument"],

  "canonical_phase2_facets": ["lambda", "hysteresis-threshold"],

  "stale_threshold_days": 90,

  "valid_verdicts": ["CLEAR", "WATCH", "BREACH"],

  "scenarios": {
    "honest_complete_fresh_clear": {
      "_description": "Canonical Phase-1 bundle: all three THEORY facets present, all THEORY discipline, frozen < 90 days ago. Verdict CLEAR.",
      "spec_bundle_id": "bundle-spec001",
      "spec_facets_rows": [
        {
          "facet_name": "gamma",
          "facet_value": "2.0",
          "freeze_discipline": "THEORY",
          "frozen_at": "__FRESH__",
          "_note": "frozen_at injected by test at reference_date - 10 days"
        },
        {
          "facet_name": "utility_family",
          "facet_value": "CRRA",
          "freeze_discipline": "THEORY",
          "frozen_at": "__FRESH__"
        },
        {
          "facet_name": "wealth_argument",
          "facet_value": "compounded_return",
          "freeze_discipline": "THEORY",
          "frozen_at": "__FRESH__"
        }
      ],
      "expected_verdict": "CLEAR",
      "expected_advisor_role": "SPEC_CRITIC",
      "expected_subject_type": "spec_bundle",
      "expected_is_advisory_only": 1,
      "_note": "raw_response must note 'all 3 facets present, all THEORY, frozen<90d'"
    },

    "missing_gamma_breach": {

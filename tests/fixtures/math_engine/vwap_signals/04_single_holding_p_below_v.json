{
  "name": "04_single_holding_p_below_v",
  "description": "Single qualifying holding with last_price < vwap -> negative diff contribution.",
  "function": "compute_vwap_signals",
  "inputs": {
    "holdings": [
      {"ticker": "QQQ", "allocation": 0.4}
    ],
    "live_vwaps": {
      "QQQ": {"last_price": 95.0, "vwap": 100.0}
    }
  },
  "expected": {
    "weighted_vwap_diff": -0.02,
    "valid_vwap_weight": 0.4
  },
  "derivation": "QQQ in live_vwaps; v=100.0 > 0. (p-v)/v = (95.0-100.0)/100.0 = -5.0/100.0 = -0.05. alloc*(p-v)/v = 0.4 * -0.05 = -0.02. valid_vwap_weight += 0.4. Final: (-0.02, 0.4)."
}

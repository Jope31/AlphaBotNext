        {"symphony_id": "s3", "triggered_reason": "Trailing Stop", "ts_et": "2026-05-16T10:31:30"},
        {"symphony_id": "s4", "triggered_reason": "Trailing Stop", "ts_et": "2026-05-16T10:31:45"},
